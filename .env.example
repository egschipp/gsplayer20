# Core auth
AUTH_SECRET=change-me
NEXTAUTH_SECRET=
AUTH_URL=https://example.com
NEXTAUTH_URL=
APP_PIN=1234
PIN_CODE=

# Spotify OAuth
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=https://example.com/api/auth/callback/spotify

# Storage
DB_PATH=/data/gsplayer.sqlite
TOKEN_ENCRYPTION_KEY=base64-encoded-32-byte-key

# Optional Redis (rate limits / cache / lock coordination)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional operations tuning
TRUST_PROXY=false
SPOTIFY_FETCH_TIMEOUT_MS=15000
SPOTIFY_GLOBAL_CONCURRENCY=8
SPOTIFY_PER_USER_CONCURRENCY=3
SPOTIFY_PER_USER_BURST=12
SPOTIFY_PER_USER_REFILL_PER_SEC=4
SPOTIFY_QUEUE_MAX_SIZE=500
SPOTIFY_QUEUE_TIMEOUT_MS=12000
SPOTIFY_CIRCUIT_FAILURE_THRESHOLD=6
SPOTIFY_CIRCUIT_OPEN_MS=12000
SPOTIFY_RETRY_AFTER_MAX_MS=120000
