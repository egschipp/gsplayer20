{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "isolatedModules": false,
    "incremental": false,
    "types": ["node"]
  },
  "include": [
    "src/features/**/*.test.ts",
    "src/features/**/actions/**/*.ts",
    "src/features/**/domain/**/*.ts",
    "src/features/**/data/**/*.ts",
    "src/features/**/types/**/*.ts",
    "src/shared/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "src/features/**/routes/**/*.ts"
  ]
}
